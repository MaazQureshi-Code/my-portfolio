# ──────────────────────────────────────────────────────────────
#  PolyLingo — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  .env.local is git-ignored automatically by Vite.
# ──────────────────────────────────────────────────────────────

# 👉 INSERT API URL HERE — your backend base URL (no trailing slash)
# Examples:
#   http://localhost:3001           (local development)
#   https://api.polylingo.com       (production)
VITE_API_BASE_URL=http://localhost:3001

# Optional: Speech-to-text / AI evaluation API key
# (used in PronunciationStep and SpeakingStep when real scoring is added)
# VITE_AI_API_KEY=your-api-key-here

# Set to true to show the demo autofill button on the login page
# Leave unset or false in production
VITE_SHOW_DEMO=true
